{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/pages/layout,_N_T_/pages/shows/layout,_N_T_/pages/shows/page,_N_T_/pages/shows"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/pages/shows/__PAGE__",
    "/pages/shows",
    "/pages",
    "/_index",
    "/_head"
  ]
}